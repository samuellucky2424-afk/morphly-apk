SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

DECART_MODEL=lucy-latest
DECART_API_KEY=your-decart-server-api-key
DECART_CLIENT_TOKEN_URL=https://configure-from-decart-dashboard.example/client-tokens

FLUTTERWAVE_ENABLED=false
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your-public-key
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your-secret-key
FLUTTERWAVE_WEBHOOK_SECRET=your-webhook-verif-hash
FLUTTERWAVE_REDIRECT_URL=morphly://payment-callback
FLUTTERWAVE_TEST_MODE=true

# strict rejects store purchase verification until Apple/Google server APIs are wired.
# sandbox_accept grants credits for local sandbox testing only.
STORE_VERIFICATION_MODE=strict
